# PromoShop Inc. — environment variables
#
# Copy this file to `.env.local` for local development, or paste the same
# names + values into Vercel → Project → Settings → Environment Variables
# for production / preview deploys.
#
# Both values come from the Supabase Dashboard:
#   Project → Settings → API
#     - Project URL              -> NEXT_PUBLIC_SUPABASE_URL
#     - anon public API key      -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# The NEXT_PUBLIC_ prefix is REQUIRED. Without it Next.js will not expose
# the value to the browser, and the site will fail to load Supabase data.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — required ONLY so /admin-dashboard can upload files to
# Supabase Storage and update database rows. The key bypasses Row-Level
# Security and has full read/write access to the project. NEVER add the
# NEXT_PUBLIC_ prefix to this variable, and never paste its value into
# client-side code. Vercel keeps server-only env vars hidden from the
# browser bundle.
#
# Find it in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
