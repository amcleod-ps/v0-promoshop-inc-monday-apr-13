# PromoShop Inc. — environment variables
#
# Copy this file to `.env.local` for local development, or paste the same
# names + values into Vercel → Project → Settings → Environment Variables
# for production / preview deploys.
#
# Both values come from the Supabase Dashboard:
#   Project → Settings → API
#     - Project URL              -> NEXT_PUBLIC_SUPABASE_URL
#     - anon public API key      -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# The NEXT_PUBLIC_ prefix is REQUIRED. Without it Next.js will not expose
# the value to the browser, and the site will fail to load Supabase data.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — required ONLY so /admin-dashboard can upload files to
# Supabase Storage and update database rows. The key bypasses Row-Level
# Security and has full read/write access to the project. NEVER add the
# NEXT_PUBLIC_ prefix to this variable, and never paste its value into
# client-side code. Vercel keeps server-only env vars hidden from the
# browser bundle.
#
# Find it in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Email notifications via Resend (optional) ------------------------------
# When RESEND_API_KEY and QUOTE_NOTIFICATION_EMAIL are both set, the site
# emails QUOTE_NOTIFICATION_EMAIL every time a visitor submits a quote
# request (homepage contact form or /my-quote). When unset, nothing is sent —
# quotes are still saved to the quote_requests table either way.
#
# Client-facing walkthrough: docs/RESEND-EMAIL-SETUP.md
#
# RESEND_API_KEY            — Resend Dashboard → API Keys ("Sending access")
# QUOTE_NOTIFICATION_EMAIL  — where notifications go; comma-separate multiple
# QUOTE_NOTIFICATION_FROM   — optional sender. Leave unset until the domain is
#                             verified in Resend; the default test sender
#                             (onboarding@resend.dev) can only deliver to the
#                             Resend account owner's own address.
# All three are server-only — never add the NEXT_PUBLIC_ prefix.
RESEND_API_KEY=re_your-api-key
QUOTE_NOTIFICATION_EMAIL=quotes@example.com
QUOTE_NOTIFICATION_FROM="PromoShop Website <quotes@example.com>"

# ── Optional: admin-dashboard access gate ───────────────────────────────────
# When set, /admin-dashboard (the page AND the server actions it calls)
# requires HTTP Basic auth: any username + this password. STRONGLY
# recommended for production — without it the only protection is that the
# URL is unlinked. Leave unset to keep the historical open behaviour.
# ADMIN_DASHBOARD_PASSWORD=pick-a-long-random-password
